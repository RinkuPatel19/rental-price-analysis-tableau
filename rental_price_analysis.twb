      <column caption='Monthly rent change' datatype='integer' name='[Calculation_952229856316317708]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEDIFF(&apos;month&apos;, LOOKUP(MIN([Pivot Field Names]), -1), MIN([Pivot Field Names]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Annual Rent Growth Rate' datatype='real' name='[Calculation_952229856317702157]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM([Pivot Field Values]) - LOOKUP(SUM([Pivot Field Values]), -12)) / LOOKUP(SUM([Pivot Field Values]), -12)'>
