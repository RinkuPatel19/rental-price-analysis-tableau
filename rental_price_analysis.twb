      <column caption='yoy growth' datatype='real' name='[Calculation_1386264271050223624]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='((SUM([Pivot Field Values]) - LOOKUP(SUM([Pivot Field Values]), -12)) / LOOKUP(SUM([Pivot Field Values]), -12))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Season' datatype='string' name='[Calculation_875387188021092358]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CASE MONTH([Pivot Field Names])&#13;&#10;  WHEN [Dec-13 (price per sq ft)]THEN &apos;Winter&apos;&#13;&#10;  WHEN [Jan-14 (price per sq ft)] THEN &apos;Winter&apos;&#13;&#10;  WHEN [Feb-14 (price per sq ft)] THEN &apos;Winter&apos;&#13;&#10;  WHEN [Mar-14 (price per sq ft)] THEN &apos;Spring&apos;&#13;&#10;  WHEN [Apr-14 (price per sq ft)] THEN &apos;Spring&apos;&#13;&#10;  WHEN [May-14 (price per sq ft)] THEN &apos;Spring&apos;&#13;&#10;  WHEN [Jun-14 (price per sq ft)] THEN &apos;Summer&apos;&#13;&#10;  WHEN [Jul-14 (price per sq ft)] THEN &apos;Summer&apos;&#13;&#10;  WHEN [Aug-14 (price per sq ft)] THEN &apos;Summer&apos;&#13;&#10;  WHEN [Sep-14 (price per sq ft)] Then &apos;Summer&apos;&#13;&#10;  WHEN [Oct-14 (price per sq ft)] THEN &apos;Fall&apos;&#13;&#10;  WHEN [Nov-14 (price per sq ft)] THEN &apos;Fall&apos;&#13;&#10;END' />
      </column>
      <column caption='rent growth rate' datatype='real' name='[Calculation_875387188037210120]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(ZN(SUM([Pivot Field Values])) - LOOKUP(ZN(SUM([Pivot Field Values])), -1)) / LOOKUP(ZN(SUM([Pivot Field Values])), -1)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Year over Year Growth' datatype='real' name='[Calculation_952229856306200583]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF ISNULL(LOOKUP(SUM([Pivot Field Values]), -1)) THEN&#13;&#10;  NULL&#13;&#10;ELSE&#13;&#10;  (SUM([Pivot Field Values]) - LOOKUP(SUM([Pivot Field Values]), -1)) / ABS(LOOKUP(SUM([Pivot Field Values]), -1))&#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Calculation1' datatype='real' name='[Calculation_952229856311025674]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(ZN(SUM([Pivot Field Values])) - LOOKUP(ZN(SUM([Pivot Field Values])), -1)) / LOOKUP(ZN(SUM([Pivot Field Values])), -1)'>
