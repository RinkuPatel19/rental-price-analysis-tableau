      </column>
      <column caption='rent concentration score' datatype='real' name='[Calculation_952229856319184911]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(AVG([Pivot Field Values]) - WINDOW_AVG(AVG([Pivot Field Values]))) * SQRT(COUNTD([City Code]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
