              <calculation class='tableau' formula='IF ISNULL(LOOKUP(SUM([Pivot Field Values]), -1)) THEN&#13;&#10;  NULL&#13;&#10;ELSE&#13;&#10;  (SUM([Pivot Field Values]) - LOOKUP(SUM([Pivot Field Values]), -1)) / ABS(LOOKUP(SUM([Pivot Field Values]), -1))&#13;&#10;END'>
