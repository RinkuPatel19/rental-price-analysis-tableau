        </calculation>
      </column>
      <column caption='percentage change in rent' datatype='real' name='[Calculation_952229856312365067]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{FIXED [City Code]: AVG([Pivot Field Values])}' />
